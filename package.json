{
  "name": "school-management",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:backend": "pnpm --filter @school/backend dev",
    "dev:frontend": "pnpm --filter @school/frontend dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "typecheck": "pnpm -r typecheck",
    "prepare": "node -e \"if(process.env.NODE_ENV !== 'production') require('child_process').execSync('husky install')\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rudney5000/school-management.git"
  },
  "bugs": {
    "url": "https://github.com/rudney5000/school-management/issues"
  },
  "homepage": "https://github.com/rudney5000/school-management#readme",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": ["eslint --fix", "prettier --write"],
    "*.{json,css,md}": ["prettier --write"]
  }
}
